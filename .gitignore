.DS_Store
.env
.env.*
local/.env
local/.env.upress
local/staging.credentials.md
# SFTP/FTP extension (Cursor/VS Code) — never commit passwords
.vscode/sftp.json
local/*.sql
local/*.zip
__pycache__/
*.pyc
.python-version
.venv/
venv/
# Google Drive desktop sync temp (avoid duplicate junk in eyal-ceo tree)
**/.tmp.driveupload/
**/.tmp.drivedownload/
# Eyal client hub build output (regenerate with scripts/build_eyal_client_hub.py)
hub/dist/
# _communication — media assets backed up on Drive, not in git
# Index files (JSON/HTML/MD) remain tracked — scanner needs them
_communication/**/media/
_communication/**/*.jpg
_communication/**/*.jpeg
_communication/**/*.png
_communication/**/*.gif
_communication/**/*.webp
_communication/**/*.mp4
_communication/**/*.mov
_communication/**/*.psd
_communication/**/*.pdf
