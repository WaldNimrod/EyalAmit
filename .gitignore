.DS_Store
.env
.env.*
local/.env
local/.env.upress
local/staging.credentials.md
# SFTP/FTP extension (Cursor/VS Code) — never commit passwords
.vscode/sftp.json
local/*.sql
local/*.zip
local/_wp_config*.php
local/_tmp_*.php
local/*.log
__pycache__/
*.pyc
.python-version
.venv/
venv/
# Google Drive desktop sync temp (avoid duplicate junk in eyal-ceo tree)
**/.tmp.driveupload/
**/.tmp.drivedownload/
# Eyal client hub build output (regenerate with scripts/build_eyal_client_hub.py)
hub/dist/
# _COMMUNICATION — media assets backed up on Drive, not in git
# Index files (JSON/HTML/MD) remain tracked — scanner needs them
_COMMUNICATION/**/media/
_COMMUNICATION/**/*.jpg
_COMMUNICATION/**/*.jpeg
_COMMUNICATION/**/*.png
_COMMUNICATION/**/*.gif
_COMMUNICATION/**/*.webp
_COMMUNICATION/**/*.mp4
_COMMUNICATION/**/*.mov
_COMMUNICATION/**/*.psd
_COMMUNICATION/**/*.pdf
# Exception: NotebookLM PDF packages are tracked (source documents, not media)
!_COMMUNICATION/team_100/**/*.pdf

# _archive QA screenshot evidence — large PNGs backed up on Drive, not git (mirrors _COMMUNICATION media rule)
_archive/**/screenshots/

# ── AOS-GOV-CACHE (Model B / ADR054) — git-ignored governance cache; refreshed by sync, never committed ──
# Hub is the audit SSoT; version held is recorded in tracked _aos/AOS_GOVERNANCE_VERSION.yaml.
/_aos/governance/
/_aos/methodology/
/_aos/lean-kit/
# ── /AOS-GOV-CACHE ──
local/video-work/
# uPress site-backup downloads (large binaries; keep on disk, never commit)
*.upress.link_*.zip
# CDP QA screenshots (large PNGs; regenerated by qa_probe --shots)
docs/qa/cdp/screenshots/

# Chapters local preview artifacts (screenshots/HTML with local file:// paths)
docs/chapters-preview/
# Local IDE / transient CDP probe runs (regenerated; evidence lives under _COMMUNICATION/)
.claude/
docs/qa/probe-*/
