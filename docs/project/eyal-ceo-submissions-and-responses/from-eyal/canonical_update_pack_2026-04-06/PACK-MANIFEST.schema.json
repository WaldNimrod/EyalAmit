{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eyalamit.local/schemas/canonical-update-pack-manifest-v1.json",
  "title": "canonical_update_pack manifest",
  "type": "object",
  "required": ["schemaVersion", "packId", "packType", "receivedDate", "artifacts"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "packId": {
      "type": "string",
      "pattern": "^canonical_update_pack_[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "packType": { "type": "string", "const": "canonical_update_pack" },
    "receivedDate": { "type": "string", "format": "date" },
    "sourceLabelHe": { "type": "string" },
    "bindingForTeams": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["relativePath", "role"],
        "properties": {
          "relativePath": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pathInRepo", "role"],
        "properties": {
          "pathInRepo": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "notesHe": { "type": "string" }
  }
}
